package dsa;
import java.util.*;

public class Switch {
	public static void main(String[] args) {
		boolean[] arr= {true,false,false,true,false,true};
		boolean[] arr1=new boolean[arr.length];
		int k=0;
		for(int i=arr.length-1;i>=0;i--) {
			arr1[k]=arr[i];
			k++;
		}
		for(int i=0;i<arr1.length;i++) {
		System.out.print(arr1[i]+" ");
		}
	}
