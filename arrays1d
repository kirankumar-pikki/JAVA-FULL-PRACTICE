package dsa;
import java.util.*;

public class Switch {
	public static void main(String[] args) {
		int[] arr= {2,5,1,9,6};
		int largest=0;
		int index=0;
		for(int i=0;i<arr.length;i++) {
			if(arr[i]>largest) {
				largest=arr[i];
				index=i;
			}
			
			
		}
		
		System.out.println(largest);
		System.out.println(index);
		
	}
}

